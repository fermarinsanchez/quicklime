---
const categoriesMenu = [
 { nombre: "INICIO", url: "/" },
 { nombre: "MUSICA", url: "/musica" },
 { nombre: "VIDEOS", url: "/videos" },
 { nombre: "CONCIERTOS", url: "/conciertos" },
 {
  nombre: "TIENDA",
  url: "https://quicklime-store.sumupstore.com/",
  target: "_blank",
 },
]

const pathname = Astro.url.pathname
const base = import.meta.env.BASE_URL
const basePath = base.replace(/\/$/, "")

function href(category: (typeof categoriesMenu)[number]) {
 if (category.target) return category.url
 return basePath + category.url
}

function isActive(category: (typeof categoriesMenu)[number]) {
 if (category.target) return false
 const fullPath = basePath + category.url
 if (category.url === "/")
  return pathname === "/" || pathname === base || pathname === fullPath
 return pathname === fullPath || pathname.startsWith(fullPath + "/")
}
---

<nav class='navbar'>
 <div class='navbar-container'>
  <div class='navbar-menu'>
   {
    categoriesMenu.map((category) => {
     const isActiveLink = isActive(category)

     return (
      <a
       href={href(category)}
       class={isActiveLink ? "is-active" : undefined}
       target={category.target}
      >
       {category.nombre}
      </a>
     )
    })
   }
  </div>
 </div>

 <style>
  /* =========================
   * Navbar (layout)
   * ========================= */
  .navbar {
   position: sticky;
   top: 0;
   width: 100%;
   max-width: 100vw;
   height: 60px;
   background-color: #fa6565;
   z-index: 1000;
   box-sizing: border-box;
  }

  .navbar-container {
   display: flex;
   height: 100%;
   /* padding adaptable para que quepan 5 items */
   padding: 0px clamp(12px, 4vw, 60px);
   box-sizing: border-box;
  }

  /* =========================
   * Navbar (menu)
   * ========================= */
  .navbar-menu {
   width: 100%;
   font-weight: 700;
   text-transform: uppercase;
   text-align: center;
   display: flex;
   justify-content: space-between;
   align-items: center;
   /* escala bien con 5 elementos */
   font-size: clamp(14px, 1.8vw, 26px);
   gap: clamp(6px, 1.2vw, 24px);
   white-space: nowrap;
  }

  .navbar-menu > a {
   text-decoration: none;
   color: #000000;
   padding: clamp(2px, 0.5vw, 6px) clamp(6px, 1vw, 14px);
   border: clamp(2px, 0.4vw, 5px) solid transparent; /* evita “saltos” al hacer hover */
  }

  .navbar-menu > a:hover {
   border-color: #000000;
  }

  .navbar-menu > a.is-active {
   border-color: #000000;
  }

  /* =========================
   * Responsive
   * ========================= */
  @media (max-width: 768px) {
   .navbar {
    height: 56px;
   }
  }

  @media (min-width: 769px) {
   .navbar {
    height: 60px;
   }
  }
 </style>
</nav>
